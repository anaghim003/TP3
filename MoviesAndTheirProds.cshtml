@model IEnumerable<CinemaManager.Models.Cinema.Movie>

@{
    ViewData["Title"] = "Films et leurs producteurs";
}

<h1>Films et leurs producteurs</h1>
<p><a asp-action="Index">Retour à la liste des films</a></p>

<table class="table">
    <thead>
        <tr>
            <th>Titre</th>
            <th>Genre</th>
            <th>Nom du producteur</th>
            <th>Nationalité du producteur</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Genre</td>
                <td>@item.Producer?.Name</td>
                <td>@item.Producer?.Nationality</td>
            </tr>
        }
    </tbody>
</table>
